{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{ "slug": "base", "name": "Base", "color": "#ffffff" },
				{ "slug": "base-accent", "name": "Base Accent", "color": "#f6f8fc" },
				{ "slug": "base-panel", "name": "Base Panel", "color": "#f0f3f9" },
				{ "slug": "contrast", "name": "Contrast", "color": "#0f172a" },
				{ "slug": "contrast-accent", "name": "Contrast Accent", "color": "#4b5675" },
				{ "slug": "contrast-muted", "name": "Contrast Muted", "color": "#8892a8" },
				{ "slug": "border", "name": "Border", "color": "#e2e7f1" },
				{ "slug": "border-strong", "name": "Border Strong", "color": "#cbd4e3" },
				{ "slug": "accent", "name": "Brand Blue", "color": "#2563eb" },
				{ "slug": "accent-dark", "name": "Brand Blue Dark", "color": "#1d4ed8" },
				{ "slug": "accent-deep", "name": "Brand Blue Deep", "color": "#1e3a6e" },
				{ "slug": "accent-light", "name": "Brand Blue Light", "color": "#dbeafe" },
				{ "slug": "cta", "name": "CTA Orange", "color": "#e85d26" },
				{ "slug": "cta-hover", "name": "CTA Orange Hover", "color": "#d14f1c" },
				{ "slug": "success", "name": "Success Green", "color": "#16a34a" },
				{ "slug": "warning", "name": "Warning Amber", "color": "#f59e0b" },
				{ "slug": "danger", "name": "Danger Red", "color": "#dc2626" }
			],
			"custom": true,
			"customGradient": false,
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false
		},
		"typography": {
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "DM Sans",
					"fontFamily": "'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"fontFace": [
						{
							"fontFamily": "DM Sans",
							"fontWeight": "400 700",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": [ "file:./assets/fonts/dm-sans/dm-sans-variable.woff2" ]
						}
					]
				},
				{
					"slug": "serif",
					"name": "Fraunces",
					"fontFamily": "'Fraunces', Georgia, 'Times New Roman', serif",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 700",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": [ "file:./assets/fonts/fraunces/fraunces-variable.woff2" ]
						},
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 700",
							"fontStyle": "italic",
							"fontStretch": "normal",
							"src": [ "file:./assets/fonts/fraunces/fraunces-italic-variable.woff2" ]
						}
					]
				},
				{
					"slug": "mono",
					"name": "JetBrains Mono",
					"fontFamily": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace",
					"fontFace": [
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "400 600",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": [ "file:./assets/fonts/jetbrains-mono/jetbrains-mono-variable.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "xs", "name": "XS", "size": "0.75rem", "fluid": false },
				{ "slug": "sm", "name": "SM", "size": "0.875rem", "fluid": false },
				{ "slug": "base", "name": "Base", "size": "1rem", "fluid": false },
				{ "slug": "md", "name": "MD", "size": "1.125rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
				{ "slug": "lg", "name": "LG", "size": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
				{ "slug": "xl", "name": "XL", "size": "2rem", "fluid": { "min": "1.5rem", "max": "2rem" } },
				{ "slug": "2xl", "name": "2XL", "size": "2.75rem", "fluid": { "min": "1.9rem", "max": "2.75rem" } },
				{ "slug": "3xl", "name": "3XL", "size": "3.5rem", "fluid": { "min": "2.4rem", "max": "3.5rem" } }
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1100px"
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true,
			"spacingScale": {
				"operator": "*",
				"increment": 1.5,
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "1rem",
			"lineHeight": "1.6"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"letterSpacing": "-0.025em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "600",
					"lineHeight": "1.18",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent-dark)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--cta)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "8px"
				},
				"spacing": {
					"padding": {
						"top": "0.85rem",
						"bottom": "0.85rem",
						"left": "2rem",
						"right": "2rem"
					}
				},
				"typography": {
					"fontWeight": "600",
					"fontSize": "0.9rem"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--cta-hover)"
					}
				}
			}
		}
	}
}
